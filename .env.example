ANTHROPIC_API_KEY=your_api_key_here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=alice@gmail.com,bob@gmail.com

# Random secret for signing session cookies (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change_me

# Public URL of the app (used for OAuth redirect)
BASE_URL=http://localhost:3001
